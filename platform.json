{
  "name": "homelab-mcp",
  "type": "go",
  "port": 8080,
  "description": "MCP server providing observability and tools for homelab infrastructure.",
  "environment": [
    "UNIFI_API_URL",
    "UNIFI_USER",
    "UNIFI_PASS",
    "PLEX_API_URL",
    "PLEX_TOKEN",
    "TAUTULLI_API_URL",
    "TAUTULLI_API_KEY",
    "SONARR_API_URL",
    "SONARR_API_KEY",
    "RADARR_API_URL",
    "RADARR_API_KEY",
    "LIDARR_API_URL",
    "LIDARR_API_KEY",
    "NZBGET_API_URL",
    "NZBGET_USER",
    "NZBGET_PASS",
    "UNRAID_URL",
    "UNRAID_API_KEY"
  ],
  "monitoring": {
    "path": "/health",
    "interval": "30s"
  }
}
